# ─── FRONTEND ENVIRONMENT VARIABLES ─────────────────────────────
# Copy this file to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Paddle
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here
NEXT_PUBLIC_PADDLE_PRICE_ID=your_paddle_price_id_here
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Change to 'production' when going live

# Audio timing (seconds)
# Set this to the timestamp in voz.mp3 where the SECOND phrase begins
# e.g. if "Y no quiero volver..." starts at 5 seconds: set to 5
NEXT_PUBLIC_VOICE_DOWNLOAD_START=4
